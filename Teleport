-- ==================== TP + AUTO GRAB (Simplified) ====================
-- Only teleport to highest brainrot and auto-steal. No UI, no extra features.

-- Services
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local TeleportService = game:GetService("TeleportService")
local LocalPlayer = Players.LocalPlayer

if not game:IsLoaded() then game.Loaded:Wait() end
pcall(function() game:GetService("Players").RespawnTime = 0 end)

-- ==================== Modules ====================
local Packages = ReplicatedStorage:WaitForChild("Packages")
local Datas = ReplicatedStorage:WaitForChild("Datas")
local Shared = ReplicatedStorage:WaitForChild("Shared")
local Utils = ReplicatedStorage:WaitForChild("Utils")

local Synchronizer = require(Packages:WaitForChild("Synchronizer"))
local AnimalsData = require(Datas:WaitForChild("Animals"))
local AnimalsShared = require(Shared:WaitForChild("Animals"))
local NumberUtils = require(Utils:WaitForChild("NumberUtils"))

-- ==================== Constants ====================
local TP_TOOL = "Flying Carpet"            -- Change if needed
local STEAL_RADIUS = 12                   -- Max distance to trigger prompt
local TP_RANGE = 70                       -- Teleport if target farther than this
local STEAL_BURST = 3                     -- Number of fires per attempt
local STEAL_DELAY = 0.12                  -- Debounce between steals

-- ==================== Helper Functions ====================
local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function getCharacter()
    return LocalPlayer.Character, 
           LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart"),
           LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
end

local function riseToY(hrp, targetY)
    if not hrp then return end
    local start = os.clock()
    while hrp.Parent and hrp.Position.Y < targetY do
        local speed = math.clamp((targetY - hrp.Position.Y) * 20, 280, 310)
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, speed, hrp.AssemblyLinearVelocity.Z)
        if os.clock() - start > 3 then break end
        RunService.Heartbeat:Wait()
    end
    hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z)
end

local function walkForward(seconds)
    local char, hrp, hum = getCharacter()
    if not hrp or not hum then return end
    local lookVector = hrp.CFrame.LookVector
    local startTime = os.clock()
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if os.clock() - startTime >= seconds then
            conn:Disconnect()
            hum:Move(Vector3.zero, false)
            return
        end
        hum:Move(lookVector, false)
    end)
end

local function equipTool(toolName)
    local char, _, hum = getCharacter()
    if not hum then return end
    local tool = LocalPlayer.Backpack:FindFirstChild(toolName) or char:FindFirstChild(toolName)
    if tool and tool.Parent ~= char then
        hum:EquipTool(tool)
        task.wait(0.02)
    end
    return tool
end

local function findAdorneeGlobal(animalData)
    if not animalData then return nil end
    local plot = Workspace:FindFirstChild("Plots") and Workspace.Plots:FindFirstChild(animalData.plot)
    if not plot then return nil end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then return nil end
    local podium = podiums:FindFirstChild(animalData.slot)
    if not podium then return nil end
    local base = podium:FindFirstChild("Base")
    if not base then return nil end
    local spawn = base:FindFirstChild("Spawn")
    if spawn then return spawn end
    return base:FindFirstChildWhichIsA("BasePart") or base
end

local function getClosestBaseSign(brainrotPart)
    if not brainrotPart then return nil end
    local closest, bestDist = nil, math.huge
    for _, label in ipairs(workspace:GetDescendants()) do
        if label:IsA("TextLabel") then
            local txt = tostring(label.Text or "")
            if txt:lower():find("base") then
                local gui = label:FindFirstAncestorWhichIsA("SurfaceGui")
                if gui then
                    local part = gui.Adornee or gui.Parent
                    if part and part:IsA("BasePart") then
                        local dist = (part.Position - brainrotPart.Position).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            closest = part
                        end
                    end
                end
            end
        end
    end
    return closest
end

-- ==================== Clone ====================
local function instantClone()
    local char, hrp, hum = getCharacter()
    if not hum then return end
    local cloner = LocalPlayer.Backpack:FindFirstChild("Quantum Cloner") or char:FindFirstChild("Quantum Cloner")
    if not cloner then return end
    if cloner.Parent ~= char then hum:EquipTool(cloner); task.wait() end

    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    local toolsFrames = PlayerGui:FindFirstChild("ToolsFrames")
    local qcFrame = toolsFrames and toolsFrames:FindFirstChild("QuantumCloner")
    local tpButton = qcFrame and qcFrame:FindFirstChild("TeleportToClone")
    if not tpButton then return end

    cloner:Activate()
    task.wait(0.15)

    if typeof(firesignal) == "function" then
        pcall(function() firesignal(tpButton.MouseButton1Click) end)
    else
        local x = tpButton.AbsolutePosition.X + tpButton.AbsoluteSize.X/2
        local y = tpButton.AbsolutePosition.Y + tpButton.AbsoluteSize.Y/2
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end
end

-- ==================== Teleport ====================
local function teleportToBrainrot(targetData)
    local char, hrp, hum = getCharacter()
    if not hrp or not hum or hum.Health <= 0 then return false end

    local targetPart = findAdorneeGlobal(targetData)
    if not targetPart then return false end

    -- Equip carpet
    equipTool(TP_TOOL)

    -- Jump and rise
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    task.wait(0.01)
    riseToY(hrp, 40)

    -- Get sign position
    local signPart = getClosestBaseSign(targetPart)
    if not signPart then return false end

    local signCF = signPart.CFrame
    local back = -signCF.LookVector
    local tpPos

    if targetPart.Position.Y <= 7 then
        tpPos = signPart.Position + (back * 20)
        tpPos = Vector3.new(tpPos.X, -4.8, tpPos.Z)
    else
        tpPos = signPart.Position + (back * 15)
        tpPos = Vector3.new(tpPos.X, signPart.Position.Y + 4, tpPos.Z)
    end

    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(tpPos)
    hrp.AssemblyLinearVelocity = Vector3.zero

    -- Wait to land
    local timeout = os.clock() + 3
    repeat
        RunService.Heartbeat:Wait()
        if not hrp.Parent then return false end
    until (hrp.Position - tpPos).Magnitude <= 2 and hum.FloorMaterial ~= Enum.Material.Air or os.clock() > timeout

    -- Mini teleport / walk
    if targetPart.Position.Y > 7 then
        hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -2.5)
    else
        walkForward(0.15)
    end
    task.wait(0.07)

    -- Clone to final position
    instantClone()
    task.wait(0.5)

    -- Final align
    if (hrp.Position - targetPart.Position).Magnitude > 3 then
        hrp.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, 2, 0))
    end
    return true
end

-- ==================== Brainrot Scanner ====================
local allAnimalsCache = {}
local lastAnimalData = {}

local function getAnimalHash(al)
    if not al then return "" end
    local h = ""
    for slot, d in pairs(al) do
        if type(d) == "table" then
            h = h .. tostring(slot) .. tostring(d.Index) .. tostring(d.Mutation)
        end
    end
    return h
end

local function scanSinglePlot(plot)
    pcall(function()
        local ch = Synchronizer:Get(plot.Name)
        if not ch then return end

        local al = ch:Get("AnimalList")
        local owner = ch:Get("Owner")
        if not owner or not owner.Name or not Players:FindFirstChild(owner.Name) then
            for i = #allAnimalsCache, 1, -1 do
                if allAnimalsCache[i].plot == plot.Name then table.remove(allAnimalsCache, i) end
            end
            return
        end

        local hash = getAnimalHash(al)
        if lastAnimalData[plot.Name] == hash then return end

        for i = #allAnimalsCache, 1, -1 do
            if allAnimalsCache[i].plot == plot.Name then table.remove(allAnimalsCache, i) end
        end

        for slot, ad in pairs(al) do
            if type(ad) == "table" then
                local aName, aInfo = ad.Index, AnimalsData[ad.Index]
                if aInfo then
                    local mutation = ad.Mutation or "None"
                    local gv = AnimalsShared:GetGeneration(aName, ad.Mutation, ad.Traits, nil)
                    local gt = "$" .. NumberUtils:ToString(gv) .. "/s"
                    table.insert(allAnimalsCache, {
                        name = aInfo.DisplayName or aName,
                        genText = gt,
                        genValue = gv,
                        mutation = mutation,
                        owner = owner.Name,
                        plot = plot.Name,
                        slot = tostring(slot),
                        uid = plot.Name .. "_" .. tostring(slot)
                    })
                end
            end
        end
        lastAnimalData[plot.Name] = hash
        table.sort(allAnimalsCache, function(a,b) return a.genValue > b.genValue end)
    end)
end

local function setupPlotListener(plot)
    scanSinglePlot(plot)
    plot.DescendantAdded:Connect(function() task.wait(0.1); scanSinglePlot(plot) end)
    plot.DescendantRemoving:Connect(function() task.wait(0.1); scanSinglePlot(plot) end)
    task.spawn(function()
        while plot.Parent do
            task.wait(5)
            scanSinglePlot(plot)
        end
    end)
end

-- Initialize plots
local plots = Workspace:WaitForChild("Plots", 8)
if plots then
    for _, p in ipairs(plots:GetChildren()) do setupPlotListener(p) end
    plots.ChildAdded:Connect(function(p) task.wait(0.5); setupPlotListener(p) end)
end

-- ==================== Steal Function ====================
local promptCache = {}
local lastFireTime = {}

local function findPromptForAnimal(animalData)
    if not animalData then return nil end
    if promptCache[animalData.uid] and promptCache[animalData.uid].Parent then
        return promptCache[animalData.uid]
    end

    local plot = Workspace.Plots:FindFirstChild(animalData.plot)
    if not plot then return nil end
    local podiums = plot:FindFirstChild("AnimalPodiums")
    if not podiums then return nil end
    local podium = podiums:FindFirstChild(animalData.slot)
    if not podium then return nil end

    local base = podium:FindFirstChild("Base")
    local spawn = base and base:FindFirstChild("Spawn")
    if not spawn then return nil end
    local attach = spawn:FindFirstChild("PromptAttachment")
    if attach then
        for _, p in ipairs(attach:GetChildren()) do
            if p:IsA("ProximityPrompt") and p.Enabled then
                promptCache[animalData.uid] = p
                return p
            end
        end
    end

    -- Fallback: search plot for nearby prompt
    local best, bestDist = nil, math.huge
    for _, desc in ipairs(plot:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local part = desc.Parent
            local pos = part and part:IsA("BasePart") and part.Position
            if pos then
                local dist = (spawn.Position - pos).Magnitude
                if dist < 8 and dist < bestDist then
                    bestDist = dist
                    best = desc
                end
            end
        end
    end
    if best then promptCache[animalData.uid] = best end
    return best
end

local function firePrompt(prompt)
    if not prompt or not prompt.Enabled then return false end
    local now = os.clock()
    if lastFireTime[prompt] and now - lastFireTime[prompt] < STEAL_DELAY then return false end
    lastFireTime[prompt] = now

    for i = 1, STEAL_BURST do
        pcall(function()
            if fireproximityprompt then
                fireproximityprompt(prompt)
            else
                prompt:InputBegan(Enum.UserInputType.MouseButton1)
                task.wait(0.02)
                prompt:InputEnded(Enum.UserInputType.MouseButton1)
            end
        end)
    end
    return true
end

-- ==================== Main Loop ====================
local function getBestTarget()
    if #allAnimalsCache == 0 then return nil end
    -- Return highest gen (first in sorted cache)
    return allAnimalsCache[1]
end

task.spawn(function()
    while true do
        local target = getBestTarget()
        if target then
            local hrp = getHRP()
            local targetPart = findAdorneeGlobal(target)
            local distance = hrp and targetPart and (hrp.Position - targetPart.Position).Magnitude or math.huge

            -- Teleport if too far
            if distance > TP_RANGE then
                teleportToBrainrot(target)
                task.wait(0.5)
                hrp = getHRP()
                targetPart = findAdorneeGlobal(target)
                distance = hrp and targetPart and (hrp.Position - targetPart.Position).Magnitude or math.huge
            end

            -- Steal if in range
            if distance <= STEAL_RADIUS then
                local prompt = findPromptForAnimal(target)
                if prompt then
                    firePrompt(prompt)
                end
            end
        end
        task.wait(0.2)
    end
end)

print("TP + Auto Grab loaded. Teleporting and stealing highest brainrot.")
