-- TP + AUTO GRAB (Simplified) - Under 200 lines
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local VirtualInputManager = game:GetService("VirtualInputManager")
local LocalPlayer = Players.LocalPlayer

if not game:IsLoaded() then game.Loaded:Wait() end
pcall(function() game:GetService("Players").RespawnTime = 0 end)

-- Modules
local Packages = ReplicatedStorage:WaitForChild("Packages")
local Datas = ReplicatedStorage:WaitForChild("Datas")
local Shared = ReplicatedStorage:WaitForChild("Shared")
local Utils = ReplicatedStorage:WaitForChild("Utils")

local Sync = require(Packages:WaitForChild("Synchronizer"))
local AnimalsData = require(Datas:WaitForChild("Animals"))
local AnimalsShared = require(Shared:WaitForChild("Animals"))
local NumberUtils = require(Utils:WaitForChild("NumberUtils"))

-- Config
local TP_TOOL = "Flying Carpet"
local STEAL_RADIUS = 12
local TP_RANGE = 70

-- Cache
local cache = {}
local lastHash = {}

local function getHRP()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getParts()
    local c = LocalPlayer.Character
    return c, c and c:FindFirstChild("HumanoidRootPart"), c and c:FindFirstChildOfClass("Humanoid")
end

local function riseToY(hrp, y)
    local start = os.clock()
    while hrp and hrp.Parent and hrp.Position.Y < y do
        local spd = math.clamp((y - hrp.Position.Y) * 20, 280, 310)
        hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, spd, hrp.AssemblyLinearVelocity.Z)
        if os.clock() - start > 3 then break end
        RunService.Heartbeat:Wait()
    end
    if hrp then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z) end
end

local function walkForward(sec)
    local _, hrp, hum = getParts()
    if not hrp or not hum then return end
    local dir = hrp.CFrame.LookVector
    local start = os.clock()
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if os.clock() - start >= sec then conn:Disconnect(); hum:Move(Vector3.zero, false) return end
        hum:Move(dir, false)
    end)
end

local function equipTool()
    local _, _, hum = getParts()
    if not hum then return end
    local t = LocalPlayer.Backpack:FindFirstChild(TP_TOOL) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(TP_TOOL))
    if t and t.Parent ~= LocalPlayer.Character then hum:EquipTool(t); task.wait(0.02) end
end

local function getAdornee(data)
    if not data then return end
    local plot = Workspace:FindFirstChild("Plots") and Workspace.Plots:FindFirstChild(data.plot)
    if not plot then return end
    local podium = plot:FindFirstChild("AnimalPodiums") and plot.AnimalPodiums:FindFirstChild(data.slot)
    if not podium then return end
    local spawn = podium:FindFirstChild("Base") and podium.Base:FindFirstChild("Spawn")
    return spawn or podium:FindFirstChildWhichIsA("BasePart")
end

local function getSign(pos)
    local best, bestD = nil, math.huge
    for _, l in ipairs(workspace:GetDescendants()) do
        if l:IsA("TextLabel") and tostring(l.Text):lower():find("base") then
            local gui = l:FindFirstAncestorWhichIsA("SurfaceGui")
            if gui then
                local part = gui.Adornee or gui.Parent
                if part and part:IsA("BasePart") then
                    local d = (part.Position - pos).Magnitude
                    if d < bestD then best, bestD = part, d end
                end
            end
        end
    end
    return best
end

local function clone()
    local _, hrp, hum = getParts()
    if not hum then return end
    local c = LocalPlayer.Backpack:FindFirstChild("Quantum Cloner") or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Quantum Cloner"))
    if not c then return end
    if c.Parent ~= LocalPlayer.Character then hum:EquipTool(c); task.wait() end
    local pg = LocalPlayer:WaitForChild("PlayerGui")
    local btn = pg:FindFirstChild("ToolsFrames") and pg.ToolsFrames:FindFirstChild("QuantumCloner") and pg.ToolsFrames.QuantumCloner:FindFirstChild("TeleportToClone")
    if not btn then return end
    c:Activate()
    task.wait(0.15)
    if typeof(firesignal) == "function" then pcall(firesignal, btn.MouseButton1Click)
    else
        local x, y = btn.AbsolutePosition.X + btn.AbsoluteSize.X/2, btn.AbsolutePosition.Y + btn.AbsoluteSize.Y/2
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end
end

local function teleport(target)
    local _, hrp, hum = getParts()
    if not hrp or not hum or hum.Health <= 0 then return false end
    local part = getAdornee(target)
    if not part then return false end
    equipTool()
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    task.wait(0.01)
    riseToY(hrp, 40)
    local sign = getSign(part.Position)
    if not sign then return false end
    local back = -sign.CFrame.LookVector
    local tpPos = part.Position.Y <= 7 and Vector3.new(sign.Position.X + back.X*20, -4.8, sign.Position.Z + back.Z*20)
                        or Vector3.new(sign.Position.X + back.X*15, sign.Position.Y + 4, sign.Position.Z + back.Z*15)
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.CFrame = CFrame.new(tpPos)
    hrp.AssemblyLinearVelocity = Vector3.zero
    local timeout = os.clock() + 3
    repeat RunService.Heartbeat:Wait() until (hrp.Position - tpPos).Magnitude <= 2 and hum.FloorMaterial ~= Enum.Material.Air or os.clock() > timeout
    if part.Position.Y > 7 then hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -2.5) else walkForward(0.15) end
    task.wait(0.07)
    clone()
    task.wait(0.5)
    if (hrp.Position - part.Position).Magnitude > 3 then hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 2, 0)) end
    return true
end

local function scanPlot(plot)
    pcall(function()
        local ch = Sync:Get(plot.Name)
        if not ch then return end
        local al = ch:Get("AnimalList")
        local owner = ch:Get("Owner")
        if not owner or not Players:FindFirstChild(owner.Name) then
            for i=#cache,1,-1 do if cache[i].plot == plot.Name then table.remove(cache,i) end end
            return
        end
        local h = ""
        for s,d in pairs(al or {}) do if type(d)=="table" then h=h..s..d.Index..(d.Mutation or "") end end
        if lastHash[plot.Name] == h then return end
        for i=#cache,1,-1 do if cache[i].plot == plot.Name then table.remove(cache,i) end end
        for s,d in pairs(al or {}) do
            if type(d)=="table" then
                local info = AnimalsData[d.Index]
                if info then
                    local gv = AnimalsShared:GetGeneration(d.Index, d.Mutation, d.Traits, nil)
                    table.insert(cache, {
                        name = info.DisplayName or d.Index,
                        gen = gv,
                        genText = "$"..NumberUtils:ToString(gv).."/s",
                        owner = owner.Name,
                        plot = plot.Name,
                        slot = tostring(s),
                        uid = plot.Name.."_"..tostring(s)
                    })
                end
            end
        end
        lastHash[plot.Name] = h
        table.sort(cache, function(a,b) return a.gen > b.gen end)
    end)
end

local function setupPlot(p)
    scanPlot(p)
    p.DescendantAdded:Connect(function() task.wait(0.1); scanPlot(p) end)
    p.DescendantRemoving:Connect(function() task.wait(0.1); scanPlot(p) end)
    task.spawn(function() while p.Parent do task.wait(5); scanPlot(p) end end)
end

local plots = Workspace:WaitForChild("Plots", 8)
if plots then
    for _, p in ipairs(plots:GetChildren()) do setupPlot(p) end
    plots.ChildAdded:Connect(function(p) task.wait(0.5); setupPlot(p) end)
end

local promptCache = {}
local lastFire = {}

local function getPrompt(data)
    if promptCache[data.uid] and promptCache[data.uid].Parent then return promptCache[data.uid] end
    local plot = Workspace.Plots:FindFirstChild(data.plot)
    if not plot then return end
    local podium = plot:FindFirstChild("AnimalPodiums") and plot.AnimalPodiums:FindFirstChild(data.slot)
    if not podium then return end
    local spawn = podium:FindFirstChild("Base") and podium.Base:FindFirstChild("Spawn")
    if not spawn then return end
    local att = spawn:FindFirstChild("PromptAttachment")
    if att then
        for _, p in ipairs(att:GetChildren()) do if p:IsA("ProximityPrompt") and p.Enabled then promptCache[data.uid]=p; return p end end
    end
    local best, bestD = nil, math.huge
    for _, d in ipairs(plot:GetDescendants()) do
        if d:IsA("ProximityPrompt") and d.Enabled then
            local pos = d.Parent and d.Parent:IsA("BasePart") and d.Parent.Position
            if pos and (spawn.Position - pos).Magnitude < 8 then local dist = (spawn.Position - pos).Magnitude
                if dist < bestD then best, bestD = d, dist end
            end
        end
    end
    if best then promptCache[data.uid]=best end
    return best
end

local function steal(prompt)
    if not prompt or not prompt.Enabled then return end
    local now = os.clock()
    if lastFire[prompt] and now - lastFire[prompt] < 0.12 then return end
    lastFire[prompt] = now
    for _=1,3 do pcall(function() if fireproximityprompt then fireproximityprompt(prompt) else prompt:InputBegan(Enum.UserInputType.MouseButton1); task.wait(0.02); prompt:InputEnded(Enum.UserInputType.MouseButton1) end end) end
end

task.spawn(function()
    while true do
        local target = cache[1]
        if target then
            local hrp = getHRP()
            local part = getAdornee(target)
            local dist = hrp and part and (hrp.Position - part.Position).Magnitude or math.huge
            if dist > TP_RANGE then teleport(target); task.wait(0.5); hrp = getHRP(); part = getAdornee(target); dist = hrp and part and (hrp.Position - part.Position).Magnitude or math.huge end
            if dist <= STEAL_RADIUS then
                local p = getPrompt(target)
                if p then steal(p) end
            end
        end
        task.wait(0.2)
    end
end)

print("TP + Auto Grab ready")
