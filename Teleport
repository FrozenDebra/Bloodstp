-- Helper functions (shortened)
local function getHRP() local c=LocalPlayer.Character return c and c:FindFirstChild("HumanoidRootPart") end
local function getParts() local c=LocalPlayer.Character return c, c and c:FindFirstChild("HumanoidRootPart"), c and c:FindFirstChildOfClass("Humanoid") end
local function riseToY(hrp,y) local s=os.clock() while hrp and hrp.Parent and hrp.Position.Y<y do local sp=math.clamp((y-hrp.Position.Y)*20,280,310) hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X,sp,hrp.AssemblyLinearVelocity.Z) if os.clock()-s>3 then break end RunService.Heartbeat:Wait() end if hrp then hrp.AssemblyLinearVelocity=Vector3.new(hrp.AssemblyLinearVelocity.X,0,hrp.AssemblyLinearVelocity.Z) end end
local function walkForward(sec) local _,hrp,hum=getParts() if not hrp or not hum then return end local dir=hrp.CFrame.LookVector local st=os.clock() local conn conn=RunService.RenderStepped:Connect(function() if os.clock()-st>=sec then conn:Disconnect() hum:Move(Vector3.zero,false) return end hum:Move(dir,false) end) end
local function equipTool() local _,_,hum=getParts() if not hum then return end local t=LocalPlayer.Backpack:FindFirstChild(TP_TOOL) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(TP_TOOL)) if t and t.Parent~=LocalPlayer.Character then hum:EquipTool(t); task.wait(0.02) end end
local function getAdornee(d) if not d then return end local p=Workspace:FindFirstChild("Plots") and Workspace.Plots:FindFirstChild(d.plot) if not p then return end local pd=p:FindFirstChild("AnimalPodiums") and p.AnimalPodiums:FindFirstChild(d.slot) if not pd then return end local sp=pd:FindFirstChild("Base") and pd.Base:FindFirstChild("Spawn") return sp or pd:FindFirstChildWhichIsA("BasePart") end
local function getSign(pos) local b,bd=nil,math.huge for _,l in ipairs(workspace:GetDescendants()) do if l:IsA("TextLabel") and tostring(l.Text):lower():find("base") then local gui=l:FindFirstAncestorWhichIsA("SurfaceGui") if gui then local part=gui.Adornee or gui.Parent if part and part:IsA("BasePart") then local d=(part.Position-pos).Magnitude if d<bd then b,bd=part,d end end end end end return b end
local function clone() local _,hrp,hum=getParts() if not hum then return end local c=LocalPlayer.Backpack:FindFirstChild("Quantum Cloner") or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Quantum Cloner")) if not c then return end if c.Parent~=LocalPlayer.Character then hum:EquipTool(c); task.wait() end local pg=LocalPlayer:WaitForChild("PlayerGui") local btn=pg:FindFirstChild("ToolsFrames") and pg.ToolsFrames:FindFirstChild("QuantumCloner") and pg.ToolsFrames.QuantumCloner:FindFirstChild("TeleportToClone") if not btn then return end c:Activate() task.wait(0.15) if typeof(firesignal)=="function" then pcall(firesignal,btn.MouseButton1Click) else local x,y=btn.AbsolutePosition.X+btn.AbsoluteSize.X/2,btn.AbsolutePosition.Y+btn.AbsoluteSize.Y/2 VirtualInputManager:SendMouseButtonEvent(x,y,0,true,game,0) task.wait(0.05) VirtualInputManager:SendMouseButtonEvent(x,y,0,false,game,0) end end
local function teleport(target) local _,hrp,hum=getParts() if not hrp or not hum or hum.Health<=0 then return false end local part=getAdornee(target) if not part then return false end equipTool() hum:ChangeState(Enum.HumanoidStateType.Jumping) task.wait(0.01) riseToY(hrp,40) local sign=getSign(part.Position) if not sign then return false end local back=-sign.CFrame.LookVector local tpPos=part.Position.Y<=7 and Vector3.new(sign.Position.X+back.X*20,-4.8,sign.Position.Z+back.Z*20) or Vector3.new(sign.Position.X+back.X*15,sign.Position.Y+4,sign.Position.Z+back.Z*15) hrp.AssemblyLinearVelocity=Vector3.zero hrp.CFrame=CFrame.new(tpPos) hrp.AssemblyLinearVelocity=Vector3.zero local timeout=os.clock()+3 repeat RunService.Heartbeat:Wait() until (hrp.Position-tpPos).Magnitude<=2 and hum.FloorMaterial~=Enum.Material.Air or os.clock()>timeout if part.Position.Y>7 then hrp.CFrame=hrp.CFrame*CFrame.new(0,0,-2.5) else walkForward(0.15) end task.wait(0.07) clone() task.wait(0.5) if (hrp.Position-part.Position).Magnitude>3 then hrp.CFrame=CFrame.new(part.Position+Vector3.new(0,2,0)) end return true end

-- Scanner
local function scanPlot(plot)
    pcall(function()
        local ch=Sync:Get(plot.Name) if not ch then return end
        local al=ch:Get("AnimalList") local owner=ch:Get("Owner")
        if not owner or not Players:FindFirstChild(owner.Name) then
            for i=#cache,1,-1 do if cache[i].plot==plot.Name then table.remove(cache,i) end end return end
        local h=""
        for s,d in pairs(al or {}) do if type(d)=="table" then h=h..s..d.Index..(d.Mutation or "") end end
        if lastHash[plot.Name]==h then return end
        for i=#cache,1,-1 do if cache[i].plot==plot.Name then table.remove(cache,i) end end
        for s,d in pairs(al or {}) do
            if type(d)=="table" then
                local info=AnimalsData[d.Index] if info then
                    local gv=AnimalsShared:GetGeneration(d.Index,d.Mutation,d.Traits,nil)
                    table.insert(cache,{name=info.DisplayName or d.Index,gen=gv,genText="$"..NumberUtils:ToString(gv).."/s",owner=owner.Name,plot=plot.Name,slot=tostring(s),uid=plot.Name.."_"..tostring(s)})
                end
            end
        end
        lastHash[plot.Name]=h
        table.sort(cache,function(a,b) return a.gen>b.gen end)
    end)
end
local function setupPlot(p) scanPlot(p) p.DescendantAdded:Connect(function() task.wait(0.1); scanPlot(p) end) p.DescendantRemoving:Connect(function() task.wait(0.1); scanPlot(p) end) task.spawn(function() while p.Parent do task.wait(5); scanPlot(p) end end) end
local plots=Workspace:WaitForChild("Plots",8) if plots then for _,p in ipairs(plots:GetChildren()) do setupPlot(p) end plots.ChildAdded:Connect(function(p) task.wait(0.5); setupPlot(p) end) end

local promptCache,lastFire={},{}
local function getPrompt(d)
    if promptCache[d.uid] and promptCache[d.uid].Parent then return promptCache[d.uid] end
    local plot=Workspace.Plots:FindFirstChild(d.plot) if not plot then return end
    local podium=plot:FindFirstChild("AnimalPodiums") and plot.AnimalPodiums:FindFirstChild(d.slot) if not podium then return end
    local spawn=podium:FindFirstChild("Base") and podium.Base:FindFirstChild("Spawn") if not spawn then return end
    local att=spawn:FindFirstChild("PromptAttachment")
    if att then for _,p in ipairs(att:GetChildren()) do if p:IsA("ProximityPrompt") and p.Enabled then promptCache[d.uid]=p; return p end end end
    local b,bd=nil,math.huge for _,p in ipairs(plot:GetDescendants()) do if p:IsA("ProximityPrompt") and p.Enabled then local pos=p.Parent and p.Parent:IsA("BasePart") and p.Parent.Position if pos then local dist=(spawn.Position-pos).Magnitude if dist<8 and dist<bd then b,bd=p,dist end end end end
    if b then promptCache[d.uid]=b end return b
end
local function steal(p)
    if not p or not p.Enabled then return end
    local n=os.clock() if lastFire[p] and n-lastFire[p]<0.12 then return end lastFire[p]=n
    for _=1,3 do pcall(function() if fireproximityprompt then fireproximityprompt(p) else p:InputBegan(Enum.UserInputType.MouseButton1) task.wait(0.02) p:InputEnded(Enum.UserInputType.MouseButton1) end end) end
end

